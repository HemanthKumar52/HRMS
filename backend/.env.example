NODE_ENV=development

# Database - Use either local PostgreSQL or Prisma Accelerate
# Local PostgreSQL:
# DATABASE_URL=postgresql://hrms:hrms_secret@localhost:5432/hrms
# Prisma Accelerate (Cloud):
DATABASE_URL=prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_PRISMA_ACCELERATE_API_KEY

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# Microsoft SSO (Azure AD / Entra ID)
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_CALLBACK_URL=http://localhost:3000/api/v1/auth/microsoft/callback
